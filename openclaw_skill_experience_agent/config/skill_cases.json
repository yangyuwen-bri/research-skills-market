{
  "agent_name": "OpenClaw Skill 体验官",
  "report_prefix": "skill-experience",
  "cases": [
    {
      "id": "S01",
      "skill": "find-skills",
      "capability": "按意图检索可安装技能并给出安装路径与可选方案",
      "skill_group": "能力发现",
      "priority": 1,
      "user_prompt": "我想给 OpenClaw 增加测试相关能力，帮我先找 3 个可直接装的技能并给安装方式。",
      "agent_reply_example": "我先按“测试能力”关键词做一次检索，先给你 3 个可用候选和安装命令。你要我直接装哪个我就继续执行。",
      "critical": true,
      "weight": 5,
      "probes": [
        {
          "label": "skills_cli_find",
          "command": "npx --yes skills ls -g | head -n 20",
          "required_exit": 0,
          "assert_contains": [
            "Global Skills",
            "Agents:"
          ],
          "optional": false
        }
      ]
    },
    {
      "id": "S02",
      "skill": "weather",
      "capability": "在对话中基于公开天气源给出即时天气结论并支持降级回退",
      "skill_group": "信息查询",
      "priority": 2,
      "user_prompt": "我刚到伦敦，今天要不要带伞？直接给我一句天气结论。",
      "agent_reply_example": "我先查伦敦实时天气，再给你一句结论：是否有降雨、体感温度和风速，方便你快速决策。",
      "critical": true,
      "weight": 5,
      "probes": [
        {
          "label": "weather_probe",
          "command": "python3 runtime_scripts/weather/weather_probe.py",
          "required_exit": 0,
          "assert_contains": [
            "wttr_primary_ok|open_meteo_fallback_ok"
          ],
          "optional": false
        }
      ]
    },
    {
