        {
          "label": "github_doc",
          "command": "grep -n \"Interact with GitHub\" references/skill_pages/github.md | head -n 1",
          "required_exit": 0,
          "assert_contains": [
            "Interact with GitHub"
          ],
          "optional": false
        }
      ]
    },
    {
      "id": "S04",
      "skill": "ontology",
      "capability": "用本地知识图谱维护实体与关系，支持创建和检索",
      "skill_group": "知识结构化",
      "priority": 4,
      "user_prompt": "我想建立一个名为『Q1技能体验』的项目节点，并关联负责人『我』，然后列出该类型实体。",
      "agent_reply_example": "我先建立项目和负责人节点，再把“负责人”关系写入图谱，最后给你回传创建结果。",
      "critical": true,
      "weight": 5,
      "probes": [
        {
          "label": "ontology_create_node",
          "command": "cd runtime_scripts/ontology && python3 ontology.py create --type Project --props '{\"name\":\"Q1技能体验\",\"status\":\"active\"}' | head -n 40",
          "required_exit": 0,
          "assert_contains": [
            "\"id\"",
            "\"type\": \"Project\"",
            "\"status\": \"active\""
          ],
          "optional": false
        },
        {
          "label": "ontology_query",
          "command": "cd runtime_scripts/ontology && python3 ontology.py query --type Project --where '{\"status\":\"active\"}' | head -n 80",
          "required_exit": 0,
          "assert_contains": [
            "\"id\"",
            "\"type\": \"Project\"",
            "\"status\": \"active\""
          ],
          "optional": false
        }
      ]
    },
